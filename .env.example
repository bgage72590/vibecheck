# VibeCheck Environment Variables
# Copy this file to .env and fill in your values

# ─── API Server ───────────────────────────────────────────
# Turso Database (https://turso.tech — free tier: 9GB)
TURSO_DATABASE_URL=libsql://your-db-name-your-org.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# Clerk Authentication (https://clerk.com — free tier: 10K MAU)
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...

# Stripe Billing (https://stripe.com)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...

# App URL (used for Stripe redirects and CORS)
APP_URL=https://vibecheck.dev

# API port (default: 3456)
PORT=3456

# ─── CLI Tool ─────────────────────────────────────────────
# Anthropic API Key for AI analysis (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# API URL override (default: https://api.vibecheck.dev)
# VIBECHECK_API_URL=http://localhost:3456
